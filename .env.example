# ========== 微信群配置 ==========
# 目标微信群名称（支持多个，用逗号分隔，必须与 wechat-cli 中显示的名称完全一致）
WECHAT_GROUP_NAME=群A,群B,群C

# ========== AI 服务商配置 ==========
# 支持: deepseek / siliconflow / zhipu / qwen / minimax
AI_PROVIDER=DeepSeek

# ── DeepSeek ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选模型: deepseek-v3-0324 / deepseek-r1-0528
DEEPSEEK_MODEL=DeepSeek-R1-0528

# ── SiliconFlow ───────────────────────────────────────────────────────────
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SILICONFLOW_MODEL=glm-5.1

# ── 智谱 GLM ─────────────────────────────────────────────────────────────
ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZHIPU_MODEL=glm-4.7

# ── 阿里云百炼 ──────────────────────────────────────────────────────────
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen3.6-plus

# ── MiniMax ───────────────────────────────────────────────────────────────
MINIMAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选模型: claude-sonnet-4.6 / claude-opus-4.6 / minimax-m2.7
MINIMAX_MODEL=claude-sonnet-4.6


# ========== Server酱3 配置 ==========
# Server酱3 SendKey（从 https://sct.ftqq.com/sendkey 获取）
SERVERCHAN_SENDKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ========== 预警配置 ==========
# 文本模型预警模式: balance（余额预警）或 token（额度预警）
TEXT_WARNING_MODE=balance

# 视觉模型预警模式: balance（余额预警）或 token（额度预警）
VISION_WARNING_MODE=token

# ── 余额预警阈值 ───────────────────────────────────────────────────────
# 账户余额预警阈值（CNY），低于此值触发推送
BALANCE_WARNING_THRESHOLD=5.0

# 视觉模型余额查询的 provider（若视觉模型使用独立服务商且启用余额预警时填写）
VISION_BALANCE_PROVIDER=

# ── Token 额度预警阈值（累计总额度，非日上限） ─────────────────────────
# 文本模型 token 总额度（仅当 TEXT_WARNING_MODE=token 时生效）
TEXT_TOKEN_TOTAL_LIMIT=1000000

# Token 预警触发比例（默认 90%）
TOKEN_WARNING_RATIO=0.9

# 视觉模型 token 总额度（仅当 VISION_WARNING_MODE=token 时生效）
VISION_TOKEN_LIMIT=1000000


# ========== 图片分析（视觉模型）配置 ==========
# 是否启用图片分析（1/true/yes 开启，默认关闭）
ENABLE_IMAGE_ANALYSIS=false

# 视觉模型 API Key（若未设置则降级使用 AI_PROVIDER）
VISION_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 视觉模型名称（支持 Claude Sonnet/Gemini 等，需与 VISION_API_KEY 配套）
# 示例: claude-sonnet-4.6 / claude-opus-4.6 / gemini-2.5-pro
VISION_MODEL=qwen-vl-plus-2025-05-07

# 视觉模型 API Base URL（可选，默认使用各服务商默认地址）
# VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
